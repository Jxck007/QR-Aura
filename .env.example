# Environment variables example for QR Aura
# Do NOT commit real secrets. Use Vercel environment settings for production.

# (Optional) Gemini API key — DO NOT expose this to client-side code. Use serverless functions.
# GEMINI_API_KEY=your_gemini_api_key_here

# Development server host/port (optional)
# VITE_DEV_HOST=0.0.0.0
# VITE_DEV_PORT=3000
