{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "QRCode": {
      "title": "QRCode",
      "description": "Stored QR code configuration and metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the QR code" },
        "userId": { "type": "string", "description": "ID of the user who created it" },
        "content": { "type": "string", "description": "The raw data/URL in the QR" },
        "type": { "type": "string", "description": "Content type (URL, WiFi, etc.)" },
        "config": { "type": "object", "description": "Full QR-Code-Styling configuration" },
        "timestamp": { "type": "number", "description": "Creation Unix timestamp" },
        "thumbnail": { "type": "string", "description": "Base64 or URL thumbnail" }
      },
      "required": ["userId", "content", "type", "config", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/qrcodes/{qrcodeId}": {
      "schema": "QRCode",
      "description": "User QR code history"
    }
  }
}
